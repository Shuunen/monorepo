{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["esnext"],
    "outDir": "out-tsc/tsc",
    "rootDir": "src",
    "tsBuildInfoFile": "out-tsc/tsc/tsconfig.lib.tsbuildinfo",
    "types": ["node"]
  },
  "exclude": ["out-tsc", "dist", "src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.stories.tsx", "vite.config.ts"],
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.ts"],
  "references": []
}
