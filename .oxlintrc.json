{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "nursery": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "restriction": "warn",
    "style": "warn",
    "suspicious": "warn"
  },
  "globals": {
    "__dirname": "readonly",
    "Audio": "readonly",
    "atob": "readonly",
    "Blob": "readonly",
    "btoa": "readonly",
    "CryptoKey": "readonly",
    "CustomEvent": "readonly",
    "clearInterval": "readonly",
    "clearTimeout": "readonly",
    "console": "readonly",
    "crypto": "readonly",
    "DOMParser": "readonly",
    "document": "readonly",
    "Element": "readonly",
    "Event": "readonly",
    "File": "readonly",
    "FileReader": "readonly",
    "FormData": "readonly",
    "fetch": "readonly",
    "Headers": "readonly",
    "HTMLAnchorElement": "readonly",
    "HTMLButtonElement": "readonly",
    "HTMLCollection": "readonly",
    "HTMLElement": "readonly",
    "HTMLImageElement": "readonly",
    "HTMLInputElement": "readonly",
    "HTMLTextAreaElement": "readonly",
    "HTMLVideoElement": "readonly",
    "KeyboardEvent": "readonly",
    "localStorage": "readonly",
    "Node": "readonly",
    "NodeFilter": "readonly",
    "NodeList": "readonly",
    "process": "readonly",
    "setInterval": "readonly",
    "setTimeout": "readonly",
    "structuredClone": "readonly",
    "TextDecoder": "readonly",
    "TextEncoder": "readonly",
    "URL": "readonly",
    "window": "readonly",
    "XMLSerializer": "readonly",
    "XPathEvaluator": "readonly",
    "XPathResult": "readonly"
  },
  "ignorePatterns": [".git", ".nx", "*.d.ts", "coverage", "dist", "node_modules", "out-tsc", "routeTree.gen.ts", "shadcn", "storybook-static", "test-output"],
  "jsPlugins": ["./libs/oxc-plugins/monorepo.plugin.js"],
  "overrides": [
    {
      "files": ["*.tsx"],
      "rules": {
        "button-has-type": "error",
        "explicit-module-boundary-types": "off",
        "max-lines-per-function": ["error", 60],
        "max-nested-callbacks": ["error", 2],
        "require-returns": "off"
      }
    },
    {
      "files": ["*.js"],
      "rules": {
        "no-unnecessary-condition": "off",
        "no-unsafe-argument": "off",
        "no-unsafe-assignment": "off",
        "no-unsafe-call": "off",
        "no-unsafe-member-access": "off",
        "no-unsafe-return": "off",
        "strict-boolean-expressions": "off",
        "use-unknown-in-catch-callback-variable": "off"
      }
    },
    {
      "files": ["**/icons/icon-*.tsx"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["**/components/src/shadcn/*.tsx"],
      "rules": {
        "arrow-body-style": "off",
        "consistent-type-imports": "off",
        "curly": "off",
        "no-magic-numbers": "off",
        "no-namespace": "off",
        "no-negated-condition": "off",
        "no-null": "off",
        "no-restricted-imports": "off",
        "sort-keys": "off"
      }
    },
    {
      "files": ["**/components/src/atoms/*.tsx"],
      "rules": {
        "no-multi-comp": "off"
      }
    },
    {
      "files": ["**/components/src/molecules/*.tsx", "**/components/src/organisms/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["lucide-react"],
                "message": "Use an icon from ../icons or create a new one"
              },
              {
                "group": ["@monorepo/components"],
                "message": "Don't import from yourself to avoid circular dependencies, use relative imports instead like ../atoms/button or ../icons/icon-error"
              },
              {
                "group": ["../shadcn/*", "!../shadcn/utils"],
                "message": "Don't import from ShadCn in molecules, import from ../atoms instead"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.js"],
      "rules": {
        "max-lines-per-function": ["error", 40],
        "max-nested-callbacks": ["error", 1]
      }
    },
    {
      "files": ["*.schema.ts", "*.schemas.ts", "schemas.ts"],
      "rules": {
        "no-magic-numbers": "off",
        "sort-keys": "off"
      }
    },
    {
      "files": ["*.machine.ts", "machine.ts"],
      "rules": {
        "ban-types": "off",
        "check-tag-names": "off",
        "func-names": "off",
        "no-empty-object-type": "off",
        "require-param": "off",
        "require-returns": "off",
        "sort-keys": "off"
      }
    },
    {
      "files": ["*.user.js"],
      "globals": {
        "addMbField": "readonly",
        "addMbSubmit": "readonly",
        "createMbForm": "readonly",
        "insertMbForm": "readonly",
        "MutationObserver": "readonly",
        "module": "readonly",
        "Shuutils": "readonly",
        "textFromSelector": "readonly"
      },
      "rules": {
        "jest/require-hook": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-statements": "off",
        "new-cap": "off",
        "no-commonjs": "off",
        "numeric-separators-style": "off",
        "prefer-module": "off"
      }
    },
    {
      "files": ["*.config.{js,ts}", "*.{cli,node}.{js,ts}", "*.test.{js,ts}"],
      "globals": {
        "__filename": "readonly",
        "Blob": "readonly",
        "Buffer": "readonly",
        "process": "readonly",
        "Response": "readonly",
        "require": "readonly",
        "URL": "readonly"
      }
    },
    {
      "files": ["*.test.{js,ts,tsx}", "vitest.*.ts", "*.mock.ts"],
      "globals": {
        "afterAll": "readonly",
        "afterEach": "readonly",
        "assert": "readonly",
        "beforeAll": "readonly",
        "beforeEach": "readonly",
        "describe": "readonly",
        "expect": "readonly",
        "expectTypeOf": "readonly",
        "it": "readonly",
        "mock": "readonly",
        "vi": "readonly"
      },
      "rules": {
        "max-nested-callbacks": "off",
        "no-nodejs-modules": "off"
      }
    },
    {
      "files": ["*.stories.tsx", "*.test.{js,ts,tsx}"],
      "rules": {
        "id-length": "off",
        "jsx-no-new-array-as-prop": "off",
        "jsx-no-new-function-as-prop": "off",
        "jsx-no-new-object-as-prop": "off",
        "jsx-props-no-spreading": "off",
        "max-classes-per-file": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-nested-callbacks": "off",
        "max-params": "off",
        "max-statements": "off",
        "no-default-export": "off",
        "no-magic-numbers": "off",
        "no-namespace": "off",
        "no-negated-condition": "off",
        "no-null": "off",
        "no-restricted-imports": "off",
        "no-shadow": "off",
        "numeric-separators-style": "off",
        "require-param": "off",
        "require-returns": "off",
        "rules-of-hooks": "off",
        "sort-keys": "off"
      }
    },
    {
      "files": ["**/routes/**/*.ts", "**/routes/**/*.tsx"],
      "rules": {
        "filename-case": "off"
      }
    },
    {
      "files": ["*.config.ts", "*.workspace.ts"],
      "rules": {
        "max-lines-per-function": "off",
        "no-anonymous-default-export": "off",
        "no-default-export": "off",
        "no-magic-numbers": "off"
      }
    },
    {
      "files": ["**/index.ts"],
      "rules": {
        "no-barrel-file": "off"
      }
    },
    {
      "files": ["**/*.{cli,node}.{js,ts}", "**/.storybook/main.{js,ts}", "*.config.ts", "apps/*-e2e/**"],
      "rules": {
        "no-nodejs-modules": "off",
        "no-process-exit": "off"
      }
    },
    {
      "files": ["libs/vite-plugins/**/*", "libs/components/.storybook/**/*", "apps/*-e2e/**"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["libs/**/*"],
      "rules": {
        "curly": "error"
      }
    },
    {
      "files": ["**/*.store.*"],
      "rules": {
        "max-nested-callbacks": ["error", 3]
      }
    }
  ],
  "plugins": ["import", "jsdoc", "oxc", "promise", "react", "react-perf", "typescript", "unicorn", "vitest"],
  "rules": {
    "array-type": "off",
    "await-thenable": "off",
    "button-has-type": "off",
    "capitalized-comments": "off",
    "consistent-indexed-object-style": "off",
    "consistent-return": "off",
    "consistent-type-definitions": ["error", "type"],
    "consistent-type-specifier-style": "off",
    "curly": ["error", "multi"],
    "explicit-function-return-type": "off",
    "explicit-module-boundary-types": "off",
    "exports-last": "off",
    "extensions": "off",
    "filename-case": [
      "error",
      {
        "case": "kebabCase"
      }
    ],
    "func-style": [
      "error",
      "declaration",
      {
        "allowArrowFunctions": true
      }
    ],
    "group-exports": "off",
    "jsdoc/require-param-type": "off",
    "jsdoc/require-returns-type": "off",
    "jsx-filename-extension": [
      "error",
      {
        "extensions": [".jsx", ".tsx"]
      }
    ],
    "jsx-handler-names": "off",
    "jsx-max-depth": [
      "error",
      {
        "max": 7
      }
    ],
    "jsx-no-jsx-as-prop": "off",
    "jsx-no-new-function-as-prop": "off",
    "jsx-no-new-object-as-prop": "off",
    "jsx-props-no-spreading": "off",
    "max-dependencies": ["error", 30],
    "max-statements": ["error", 20],
    "monorepo-plugin/no-restricted-syntax": [
      "error",
      {
        "message": "Please use dedicated auto-form utils instead of native Zod .meta({ myMeta }), use `field(z.string(), { myMeta })` instead for example.",
        "selector": "CallExpression[callee.property.name='meta']"
      }
    ],
    "no-array-index-key": "off",
    "no-array-index-key : conflicts with useStableKeys": "off",
    "no-async-await": "off",
    "no-base-to-string": "off",
    "no-confusing-void-expression": "off",
    "no-console": "error",
    "no-continue": "off",
    "no-default-export": "error",
    "no-deprecated": "off",
    "no-floating-promises": "off",
    "no-implied-eval": "off",
    "no-inline-comments": "off",
    "no-magic-numbers": [
      "error",
      {
        "ignore": [-1, 0, 1],
        "ignoreClassFieldInitialValues": true,
        "ignoreDefaultValues": true
      }
    ],
    "no-map-spread": "off",
    "no-meaningless-void-operator": "off",
    "no-misused-promises": "off",
    "no-named-export": "off",
    "no-optional-chaining": "off",
    "no-redundant-type-constituents": "off",
    "no-relative-parent-imports": "off",
    "no-rest-spread-properties": "off",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["lucide-react"],
            "message": "Use an generic icon from \"@monorepo/components\" or create a new one"
          },
          {
            "group": ["@tanstack/react-query"],
            "message": "Don't directly use the react-query hooks, use the hooks from api.ts instead"
          }
        ]
      }
    ],
    "no-ternary": "off",
    "no-unassigned-import": "off",
    "no-undefined": "off",
    "no-unescaped-entities": "off",
    "no-unnecessary-boolean-literal-compare": "off",
    "no-unnecessary-condition": "off",
    "no-unnecessary-template-expression": "off",
    "no-unnecessary-type-arguments": "off",
    "no-unnecessary-type-assertion": "off",
    "no-unnecessary-type-parameters": "off",
    "no-unsafe-argument": "off",
    "no-unsafe-assignment": "off",
    "no-unsafe-call": "off",
    "no-unsafe-member-access": "off",
    "no-unsafe-type-assertion": "off",
    "no-use-before-define": [
      "error",
      {
        "functions": false
      }
    ],
    "no-useless-default-assignment": "off",
    "no-useless-undefined": "off",
    "no-void": "off",
    "no-warning-comments": "off",
    "non-nullable-type-assertion-style": "off",
    "number-literal-case": "off",
    "prefer-default-export": "off",
    "prefer-destructuring": "off",
    "prefer-nullish-coalescing": "off",
    "prefer-optional-chain": "off",
    "prefer-promise-reject-errors": "off",
    "prefer-readonly": "off",
    "prefer-readonly-parameter-types": "off",
    "prefer-regexp-exec": "off",
    "prefer-ternary": "off",
    "promise-function-async": "off",
    "promise/avoid-new": "off",
    "react-in-jsx-scope": "off",
    "restrict-template-expressions": "off",
    "return-await": "off",
    "sort-imports": "off",
    "strict-boolean-expressions": "off",
    "strict-void-return": "off",
    "switch-exhaustiveness-check": "off",
    "unambiguous": "off",
    "unbound-method": "off",
    "unicorn/prefer-spread": "off",
    "use-unknown-in-catch-callback-variable": "off",
    "vitest/prefer-called-times": "off",
    "vitest/prefer-to-be-falsy": "off",
    "vitest/prefer-to-be-truthy": "off",
    "yoda": "off"
  }
}
